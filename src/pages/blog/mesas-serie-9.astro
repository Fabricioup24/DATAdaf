---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import MapContainer from '../../components/mesas-serie-9';
import MethodologySheet from '../../components/MethodologySheet';
import Labels from '../../components/labels';
---

<Layout 
  title="Visualización espacial de las mesas de la serie 900 | DATAdaf"
  description="Este mapa presenta la ubicación de los locales vinculados a mesas serie 900 y la distribución de sus votos, con base en registros electorales y criterios de procesamiento documentados."
  showNativeScrollbar={true}
>
  <div id="main-wrapper" class="page-ready bg-white min-h-screen text-[#121212]">
    <Navbar 
      client:load 
      variant="light" 
    />

    <main class="pt-36 md:pt-48 pb-16 md:pb-24 px-5 sm:px-8 relative z-10">
      <article class="max-w-4xl mx-auto">
        <div class="mb-10 md:mb-12">
          <div class="flex flex-wrap items-center gap-3 md:gap-4 mb-8">
            <Labels category="geolocalizacion" client:load />
            <Labels category="ciencia-de-datos" client:load />
            <div class="hidden sm:block h-px w-8 bg-[#121212]/10"></div>
            <time class="text-xs font-bold text-[#121212]/40 uppercase tracking-widest">27 de Abril, 2026</time>
          </div>
          
          <h1 class="text-[clamp(2.5rem,12vw,3.75rem)] md:text-8xl font-black mb-8 md:mb-10 leading-[0.92] md:leading-[0.9] tracking-tighter text-[#121212]">
            Visualización espacial de las <br/>
            <span class="text-blue-600">mesas de la serie 900</span>
          </h1>
          
          <p class="text-lg md:text-2xl text-[#121212]/70 font-medium leading-relaxed max-w-2xl">
            Este mapa presenta la ubicación de los locales vinculados a mesas serie 900 y la distribución de sus votos, con base en registros electorales y criterios de procesamiento documentados.
          </p>
        </div>

        <section class="mb-16">
          <div class="prose prose-lg max-w-none mb-12">
            
            <div class="glass-card p-5 sm:p-8 my-8 md:my-10 border-l-4 border-blue-600 bg-blue-50/30">
              <h3 class="text-xl font-black mb-4 uppercase tracking-wider text-blue-900">Contexto</h3>
              <p class="text-blue-900/80 leading-relaxed mb-4">
                Las mesas con identificadores entre <strong>900001</strong> y <strong>904703</strong> corresponden a centros poblados. Según la ONPE, están integradas por electores que residen en comunidades alejadas de la capital distrital y se implementan desde <strong>2005</strong> para facilitar el acceso al sufragio en zonas de difícil traslado.
              </p>
              <p class="text-blue-900/75 leading-relaxed">
                Este reporte muestra la ubicación de los locales asociados y la distribución de sus votos para fines de transparencia y análisis territorial.
              </p>
            </div>

            <p>
              Esta visualización ofrece una base espacial para examinar la distribución territorial de los locales vinculados a las mesas serie 900 y observar la distribución de sus votos en el marco de las Elecciones Generales 2026.
            </p>
          </div>

          <!-- Map Implementation -->
          <div class="my-10 md:my-12 relative left-1/2 w-screen max-w-[min(98rem,calc(100vw-0.5rem))] -translate-x-1/2 px-0 sm:px-2 md:px-4">
            <h2 class="text-xl sm:text-2xl font-black mb-5 md:mb-6 uppercase tracking-widest">Mapa de Ubicaciones</h2>
            <MapContainer 
              client:load 
              dataUrl="/pdfs/01_base_4703_mesas_serie9_con_coordenadas.csv"
              initialCenter={[-75.0152, -9.19]}
              initialZoom={5}
              height="clamp(620px, 84vh, 980px)"
            />
            <p class="mt-4 text-sm text-[#121212]/40 italic">
              * El mapa muestra locales de votación asociados a las mesas serie 900; cada punto agrupa sus mesas vinculadas.
            </p>
          </div>

          <MethodologySheet client:load />
        </section>

        <footer class="border-t border-gray-100 pt-12 mt-24">
          <a href="/blog" class="inline-flex items-center gap-3 font-black text-xs uppercase tracking-widest group">
            <div class="w-8 h-[2px] bg-[#121212] transition-all duration-300 group-hover:w-12"></div>
            Volver al Blog
          </a>
        </footer>
      </article>
    </main>
  </div>
</Layout>

<style>
  /* Custom styles for the blog post */
  article {
    animation: fadeIn 0.8s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
