---
import '@fontsource/manrope/400.css';
import '@fontsource/manrope/600.css';
import '@fontsource/manrope/700.css';
import '@fontsource/manrope/800.css';
import '../styles/global.css';

interface Props {
	title?: string;
    description?: string;
}

const { title = "DATAdaf - Análisis de Datos Inteligentes", description = "Soluciones avanzadas en ciencia de datos, machine learning y visualización" } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<link rel="icon" type="image/svg+xml" href="/favicomdata.svg" />
		<link rel="dns-prefetch" href="https://www.linkedin.com" />
		<link rel="dns-prefetch" href="https://www.instagram.com" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://www.datadaf.com/" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="https://www.datadaf.com/graficos/datadafnegro.png" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content="https://www.datadaf.com/" />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content="https://www.datadaf.com/graficos/datadafnegro.png" />

		<!-- JSON-LD -->
		<script type="application/ld+json" is:inline set:html={`
		{
		  "@context": "https://schema.org",
		  "@type": "ConsultingService",
		  "name": "DATAdaf",
		  "image": "https://www.datadaf.com/graficos/datadafnegro.png",
		  "url": "https://www.datadaf.com/",
		  "telephone": "+51934988647",
		  "address": {
		    "@type": "PostalAddress",
		    "addressLocality": "Lima",
		    "addressCountry": "PE"
		  },
		  "description": "Soluciones avanzadas en ciencia de datos, machine learning y visualización.",
		  "sameAs": [
		    "https://www.linkedin.com/company/datadaf",
		    "https://www.instagram.com/datadaf"
		  ]
		}
		`} />
	</head>
	<body>
		<slot />
        
        <script>
            import Lenis from 'lenis';
            import gsap from 'gsap';
            import ScrollTrigger from 'gsap/ScrollTrigger';

            gsap.registerPlugin(ScrollTrigger);

            if (window.__datadafLenisCleanup) {
                window.__datadafLenisCleanup();
            }

            const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            const lenis = new Lenis({
                autoRaf: false,
                duration: prefersReducedMotion ? 0.01 : 1.1,
                easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
                smoothWheel: !prefersReducedMotion,
                wheelMultiplier: 1,
                touchMultiplier: prefersReducedMotion ? 1 : 1.4,
            });

            window.lenis = lenis;
            lenis.on('scroll', ScrollTrigger.update);

            let rafId = 0;
            const raf = (time) => {
                lenis.raf(time);
                rafId = window.requestAnimationFrame(raf);
            };
            rafId = window.requestAnimationFrame(raf);

            gsap.ticker.lagSmoothing(0);

            window.__datadafLenisCleanup = () => {
                window.cancelAnimationFrame(rafId);
                lenis.destroy();
                delete window.lenis;
            };
        </script>
	</body>
</html>
